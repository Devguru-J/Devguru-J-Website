{
  "name": "memory-website",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "test": "playwright test",
    "verify": "npm run check && npm run lint && npm run build && npm test",
    "generate:icons": "node scripts/generate-icons.mjs",
    "generate:og": "node scripts/generate-og.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/geist": "^5.2.5",
    "@fontsource-variable/geist-mono": "^5.2.5",
    "@tailwindcss/vite": "^4.1.11",
    "astro": "^5.12.0",
    "pretendard": "^1.3.9",
    "tailwindcss": "^4.1.11"
  },
  "_overridesNote": "Astro 5 bundles Vite 6. Without the override, @tailwindcss/vite pulls a second Vite whose Plugin type is structurally incompatible and `astro check` fails.",
  "overrides": {
    "vite": "^6.4.3"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.27.7": true,
    "sharp@0.34.5": true
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "astro-eslint-parser": "^3.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0"
  }
}
