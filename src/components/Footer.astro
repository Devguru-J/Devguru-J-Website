---
import { translations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = translations[lang].footer;
const home = lang === 'ko' ? '/ko/' : '/';
const year = new Date().getFullYear();
---

<footer class="bg-canvas" id="contact">
  <!-- contact statement -->
  <div class="mx-auto max-w-[1280px] px-5 pt-24 pb-16 md:px-12 md:pt-32">
    <span class="label-mono reveal mb-8 block text-amber">{t.overline}</span>
    <div class="flex flex-col gap-10 md:flex-row md:items-end md:justify-between">
      <h2 class="display-xl reveal max-w-3xl text-ink">
        {t.headline1}<br />
        <span class="text-ink-2">{t.headline2}</span>
      </h2>
      <a
        href="mailto:devguru.j610@gmail.com"
        class="label-mono magnetic reveal inline-block shrink-0 bg-ink px-8 py-4 text-canvas transition-colors duration-300 hover:bg-amber"
      >
        {t.cta}
      </a>
    </div>
  </div>

  <div
    class="mx-auto flex max-w-[1280px] flex-col items-start justify-between px-5 py-16 md:flex-row md:px-12"
  >
    <div class="mb-12 md:mb-0">
      <div class="label-mono mb-6 font-bold text-ink">DEVGURU-J / SEOUL</div>
      <p class="label-mono max-w-[240px] leading-relaxed text-ink-2">{t.tagline}</p>
    </div>
    <div class="grid grid-cols-2 gap-16">
      <div>
        <h5 class="label-mono mb-6 text-ink">Directory</h5>
        <ul class="space-y-4">
          <li><a href={`${home}#work`} class="label-mono text-ink-2 transition-colors hover:text-ink">Work</a></li>
          <li><a href={`${home}#capabilities`} class="label-mono text-ink-2 transition-colors hover:text-ink">Capabilities</a></li>
          <li><a href={`${home}#principles`} class="label-mono text-ink-2 transition-colors hover:text-ink">Principles</a></li>
          <li><a href={`${home}#about`} class="label-mono text-ink-2 transition-colors hover:text-ink">About</a></li>
        </ul>
      </div>
      <div>
        <h5 class="label-mono mb-6 text-ink">Elsewhere</h5>
        <ul class="space-y-4">
          <li>
            <a
              href="https://github.com/Devguru-J"
              target="_blank"
              rel="noopener"
              class="label-mono text-ink-2 transition-colors hover:text-ink">GitHub</a
            >
          </li>
          <li>
            <a
              href="mailto:devguru.j610@gmail.com"
              class="label-mono text-ink-2 transition-colors hover:text-ink">Email</a
            >
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div
    class="mx-auto flex max-w-[1280px] flex-col items-center justify-between border-t border-line/50 px-5 py-8 md:flex-row md:px-12"
  >
    <span class="meta-mono mb-4 uppercase text-ink-2 md:mb-0">
      © {year} DEVGURU-J / ALL RIGHTS RESERVED
    </span>
    <div class="flex gap-8">
      <a href="/MonkeyFlash/privacy" class="meta-mono uppercase text-ink-2 transition-colors hover:text-ink">Privacy</a>
      <a href="/MonkeyFlash/support" class="meta-mono uppercase text-ink-2 transition-colors hover:text-ink">Support</a>
    </div>
  </div>
</footer>
