---
import { translations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = translations[lang].footer;
const home = lang === 'ko' ? '/ko/' : '/';
const year = new Date().getFullYear();

const ui =
  lang === 'ko'
    ? {
        brand: '기억 / 독립 스튜디오',
        group1: '둘러보기',
        work: '작업',
        capabilities: '작업 범위',
        principles: '원칙',
        about: '소개',
        group2: '연락',
        github: 'GitHub',
        email: '이메일',
        privacy: '개인정보처리방침',
        support: '지원',
        rights: `© ${year} 기억 / ALL RIGHTS RESERVED`,
      }
    : {
        brand: 'MEMORY / INDEPENDENT STUDIO',
        group1: 'Directory',
        work: 'Work',
        capabilities: 'Scope',
        principles: 'Principles',
        about: 'About',
        group2: 'Elsewhere',
        github: 'GitHub',
        email: 'Email',
        privacy: 'Privacy',
        support: 'Support',
        rights: `© ${year} MEMORY / ALL RIGHTS RESERVED`,
      };
---

<footer class="bg-canvas" id="contact">
  <!-- contact statement -->
  <div class="mx-auto max-w-[1280px] px-5 pt-24 pb-16 md:px-12 md:pt-32">
    <span class="label-mono reveal mb-8 block text-amber">{t.overline}</span>
    <div class="flex flex-col gap-10 md:flex-row md:items-end md:justify-between">
      <h2 class="display-xl reveal max-w-3xl text-ink">
        {t.headline1}<br />
        <span class="text-ink-2">{t.headline2}</span>
      </h2>
      <a
        href="mailto:devguru.j610@gmail.com"
        class="label-mono magnetic reveal inline-block shrink-0 bg-ink px-8 py-4 text-canvas transition-colors duration-300 hover:bg-amber"
      >
        {t.cta}
      </a>
    </div>
  </div>

  <div
    class="mx-auto flex max-w-[1280px] flex-col items-start justify-between px-5 py-16 md:flex-row md:px-12"
  >
    <div class="mb-12 md:mb-0">
      <div class="label-mono mb-6 font-bold text-ink">{ui.brand}</div>
      <p class="label-mono max-w-[240px] leading-relaxed text-ink-2">{t.tagline}</p>
    </div>
    <div class="grid grid-cols-2 gap-16">
      <div>
        <h5 class="label-mono mb-6 text-ink">{ui.group1}</h5>
        <ul class="space-y-4">
          <li><a href={`${home}#work`} class="label-mono text-ink-2 transition-colors hover:text-ink">{ui.work}</a></li>
          <li><a href={`${home}#capabilities`} class="label-mono text-ink-2 transition-colors hover:text-ink">{ui.capabilities}</a></li>
          <li><a href={`${home}#principles`} class="label-mono text-ink-2 transition-colors hover:text-ink">{ui.principles}</a></li>
          <li><a href={`${home}#about`} class="label-mono text-ink-2 transition-colors hover:text-ink">{ui.about}</a></li>
        </ul>
      </div>
      <div>
        <h5 class="label-mono mb-6 text-ink">{ui.group2}</h5>
        <ul class="space-y-4">
          <li>
            <a
              href="https://github.com/Devguru-J"
              target="_blank"
              rel="noopener"
              class="label-mono text-ink-2 transition-colors hover:text-ink">{ui.github}</a
            >
          </li>
          <li>
            <a
              href="mailto:devguru.j610@gmail.com"
              class="label-mono text-ink-2 transition-colors hover:text-ink">{ui.email}</a
            >
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div
    class="mx-auto flex max-w-[1280px] flex-col items-center justify-between border-t border-line/50 px-5 py-8 md:flex-row md:px-12"
  >
    <span class="meta-mono mb-4 uppercase text-ink-2 md:mb-0">
      {ui.rights}
    </span>
    <div class="flex gap-8">
      <a href="/MonkeyFlash/privacy" class="meta-mono uppercase text-ink-2 transition-colors hover:text-ink">{ui.privacy}</a>
      <a href="/MonkeyFlash/support" class="meta-mono uppercase text-ink-2 transition-colors hover:text-ink">{ui.support}</a>
    </div>
  </div>
</footer>
