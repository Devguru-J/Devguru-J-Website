---
/**
 * Wordmark — §16 Direction A.
 *
 * Two official wordmarks of equal weight: `기억` on Korean pages, `Memory` on
 * English pages. They are never shown together outside brand guidelines (§16.4).
 *
 * Set in the brand faces with optical tuning rather than a paid display face,
 * and drawn in `currentColor` so light, dark, and print share one form.
 */
import { BRAND } from '../config/site';
import type { Lang } from '../config/site';

interface Props {
  lang: Lang;
  /** Visual cap height in px. Nav uses 20–22px desktop, 18–20px mobile (§8.1). */
  size?: number;
}

const { lang, size = 21 } = Astro.props;
---

<span class:list={['wordmark', `wordmark--${lang}`]} style={`--wm-size:${size}px`}>
  {BRAND[lang]}
</span>

<style>
  .wordmark {
    display: inline-block;
    color: currentColor;
    font-size: var(--wm-size);
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
    /* fixed box so the nav never reflows between locales */
    font-feature-settings: 'kern' 1;
  }

  /* Latin: tight, precise, slightly closed apertures */
  .wordmark--en {
    font-family: 'Geist Variable', Inter, ui-sans-serif, system-ui, sans-serif;
    letter-spacing: -0.035em;
  }

  /* Hangul: Pretendard needs looser tracking than Geist to read at the same
     optical weight, and must not be condensed. */
  .wordmark--ko {
    font-family: 'Pretendard Variable', 'Apple SD Gothic Neo', 'Noto Sans KR', sans-serif;
    letter-spacing: 0.01em;
    font-size: calc(var(--wm-size) * 1.02);
  }
</style>
