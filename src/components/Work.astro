---
import { content, type Lang } from '../i18n';
const { lang = 'en' } = Astro.props as { lang?: Lang };
const t = content[lang];
---

<section class="work" id="work" data-bg="#F4F4F2">
  <p class="label" data-anim>{t.work.label}</p>
  <div class="work-list">
    {
      t.work.projects.map((p, i) => (
        <a
          class="work-item"
          href={p.href}
          target={p.href.startsWith('http') ? '_blank' : undefined}
          rel={p.href.startsWith('http') ? 'noopener' : undefined}
          data-img={p.key}
          data-anim
          data-delay={`${i * 150}`}
        >
          <h2>{p.title}</h2>
          <span class="wi-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M6 18 18 6M8 6h10v10" />
            </svg>
          </span>
        </a>
      ))
    }
    <div class="work-follow">
      {t.work.projects.map((p) => <img src={p.img} alt="" data-key={p.key} loading="lazy" />)}
    </div>
  </div>
</section>
