---
import Base from '../layouts/Base.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import { EMAIL, LANG_COOKIE, LEGACY_LANG_KEY } from '../config/site';
import type { Lang } from '../config/site';
import type { LegalDoc } from '../content/legal';
import { translations } from '../i18n';

interface Props {
  doc: LegalDoc;
  lang: Lang;
  title: string;
  /** Canonical path for this locale, with trailing slash. */
  path: string;
  /** Same document in the other language. */
  altPath: string;
}

const { doc, lang, title, path, altPath } = Astro.props;
const t = translations[lang];
---

<Base
  title={title}
  description={doc.description}
  path={path}
  lang={lang}
  altPath={altPath}
  ogImage={`/assets/og-monkeyflash-${lang}.png`}
>
  <Nav lang={lang} altPath={altPath} />

  <main id="main" class="shell legal-main">
    <p class="t-label legal-overline">{doc.overline}</p>
    <h1 class="t-h2 legal-heading">{doc.heading}</h1>
    <p class="legal-standfirst">{doc.standfirst}</p>

    <div class="legal">
      {
        doc.blocks.map((block) => {
          switch (block.type) {
            case 'h2':
              return <h2>{block.text}</h2>;
            case 'h3':
              return <h3>{block.text}</h3>;
            case 'ol':
              return (
                <ol>
                  {block.items.map((i) => (
                    <li>{i}</li>
                  ))}
                </ol>
              );
            case 'ul':
              return (
                <ul>
                  {block.items.map((i) => (
                    <li>{i}</li>
                  ))}
                </ul>
              );
            case 'contact':
              return (
                <div class="contact-card">
                  <strong>{block.label}</strong>
                  <br />
                  {block.before}
                  <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
                  {block.after}
                </div>
              );
            default:
              return 'strong' in block ? (
                <p>
                  <strong>{block.text}</strong>
                </p>
              ) : (
                <p>{block.text}</p>
              );
          }
        })
      }
    </div>

    <p class="legal-back">
      <a href={lang === 'ko' ? '/ko/' : '/'} class="link">{t.legal.backHome}</a>
    </p>
  </main>

  <Footer lang={lang} withContact={false} />

  <script
    is:inline
    define:vars={{ altPath, lang, cookieName: LANG_COOKIE, legacyKey: LEGACY_LANG_KEY }}
  >
    /* Backwards compatibility for the old query/localStorage language toggle.
       The URL is now the single source of language state (§7.4), so a legacy
       `?lang=` value is honoured once by redirecting to the real locale route. */
    (function () {
      try {
        const requested = new URLSearchParams(location.search).get('lang');
        const legacy = localStorage.getItem(legacyKey);

        if (legacy) {
          document.cookie =
            cookieName + '=' + legacy + ';path=/;max-age=31536000;samesite=lax';
          localStorage.removeItem(legacyKey);
        }

        if ((requested === 'ko' || requested === 'en') && requested !== lang) {
          location.replace(altPath);
        }
      } catch {
        /* storage blocked — the canonical URL already carries the language */
      }
    })();
  </script>
</Base>

<style is:global>
  .legal-main {
    max-width: 760px;
    padding-block: clamp(48px, 7vw, 88px) clamp(72px, 9vw, 120px);
  }

  .legal-overline {
    color: var(--color-accent);
    margin-bottom: 20px;
  }

  .legal-heading {
    margin-bottom: 10px;
  }

  .legal-standfirst {
    color: var(--color-ink-2);
    font-size: 15px;
    line-height: 1.7;
    max-width: 65ch;
    margin-bottom: 40px;
  }

  .legal h2 {
    font-size: 19px;
    letter-spacing: -0.01em;
    font-weight: 500;
    margin: 44px 0 12px;
  }

  .legal h3 {
    font-size: 16px;
    font-weight: 500;
    margin: 24px 0 6px;
    color: var(--color-ink);
  }

  .legal p {
    color: var(--color-ink-2);
    line-height: 1.7;
    margin-bottom: 14px;
    max-width: 65ch;
  }

  .legal ol,
  .legal ul {
    color: var(--color-ink-2);
    line-height: 1.7;
    margin: 0 0 14px;
    padding-left: 22px;
    max-width: 65ch;
  }

  .legal ol {
    list-style: decimal;
  }
  .legal ul {
    list-style: disc;
  }
  .legal li {
    margin-bottom: 6px;
  }

  .legal strong {
    color: var(--color-ink);
  }

  .legal a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .legal .contact-card {
    margin-top: 32px;
    padding: 28px 32px;
    background: var(--color-raised);
    border: 1px solid var(--color-line);
    border-radius: 4px;
    color: var(--color-ink-2);
    line-height: 1.8;
  }

  .legal-back {
    margin-top: 48px;
  }
</style>
