---
import LogoMorph from './LogoMorph.astro';
import type { Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const home = lang === 'ko' ? '/ko/' : '/';

const labels =
  lang === 'ko'
    ? { work: '작업', capabilities: '작업 범위', principles: '원칙', about: '소개', contact: '문의' }
    : { work: 'Work', capabilities: 'Scope', principles: 'Principles', about: 'About', contact: 'Contact' };

const menuLabels = lang === 'ko' ? { open: '메뉴', close: '닫기' } : { open: 'MENU', close: 'CLOSE' };
const menuAria =
  lang === 'ko' ? { open: '메뉴 열기', close: '메뉴 닫기' } : { open: 'Open menu', close: 'Close menu' };

const links = [
  { href: `${home}#work`, label: labels.work },
  { href: `${home}#capabilities`, label: labels.capabilities },
  { href: `${home}#principles`, label: labels.principles },
  { href: `${home}#about`, label: labels.about },
  { href: `${home}#contact`, label: labels.contact },
];
---

<nav
  class="sticky top-0 z-50 border-b border-line bg-canvas/80 backdrop-blur-md"
  id="site-nav"
>
  <div
    class="mx-auto flex max-w-[1280px] items-center justify-between px-5 py-6 md:px-12"
  >
    <a href={home} class="text-[24px] font-bold text-ink"><LogoMorph lang={lang} /></a>

    <div class="hidden items-center gap-8 md:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="label-mono text-ink-2 transition-colors duration-200 hover:text-amber"
          >
            {l.label}
          </a>
        ))
      }
      <span class="label-mono flex items-center gap-2">
        <a
          href="/"
          data-set-lang="en"
          class:list={['transition-colors', lang === 'en' ? 'text-ink' : 'text-ink-2 hover:text-amber']}
          aria-current={lang === 'en' ? 'true' : undefined}>EN</a
        >
        <span class="text-line">/</span>
        <a
          href="/ko/"
          data-set-lang="ko"
          class:list={['transition-colors', lang === 'ko' ? 'text-ink' : 'text-ink-2 hover:text-amber']}
          aria-current={lang === 'ko' ? 'true' : undefined}>KO</a
        >
      </span>
    </div>

    <div class="flex items-center gap-5 md:hidden">
      <span class="label-mono flex items-center gap-2">
        <a href="/" data-set-lang="en" class:list={[lang === 'en' ? 'text-ink' : 'text-ink-2']}>EN</a>
        <span class="text-line">/</span>
        <a href="/ko/" data-set-lang="ko" class:list={[lang === 'ko' ? 'text-ink' : 'text-ink-2']}>KO</a>
      </span>
      <button
        class="label-mono text-ink"
        id="menu-toggle"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={menuAria.open}
      >
        {menuLabels.open}
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-line bg-canvas md:hidden">
    <div class="flex flex-col gap-6 px-5 py-8">
      {
        links.map((l) => (
          <a href={l.href} class="label-mono text-ink" data-menu-link>
            {l.label.toUpperCase()}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  // locale read from the document itself, so no new markup or attributes are needed
  const ko = document.documentElement.lang === 'ko';
  const LABEL_OPEN = ko ? '메뉴' : 'MENU';
  const LABEL_CLOSE = ko ? '닫기' : 'CLOSE';
  const ARIA_OPEN = ko ? '메뉴 열기' : 'Open menu';
  const ARIA_CLOSE = ko ? '메뉴 닫기' : 'Close menu';
  if (toggle && menu) {
    const close = () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', ARIA_OPEN);
      toggle.textContent = LABEL_OPEN;
    };
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? ARIA_CLOSE : ARIA_OPEN);
      toggle.textContent = open ? LABEL_CLOSE : LABEL_OPEN;
    });
    menu.querySelectorAll('[data-menu-link]').forEach((a) => a.addEventListener('click', close));
  }

  // explicit language choice wins over the geo default (read by the edge function on "/")
  document.querySelectorAll<HTMLAnchorElement>('[data-set-lang]').forEach((a) => {
    a.addEventListener('click', () => {
      document.cookie = `lang=${a.dataset.setLang};path=/;max-age=31536000;samesite=lax`;
    });
  });
</script>
