---
import { content, type Lang } from '../i18n';
const { lang = 'en' } = Astro.props as { lang?: Lang };
const t = content[lang];
---

<section class="services" id="services" data-bg="#F4F4F2">
  <div class="services-head">
    <h2 data-anim>{t.services.heading}</h2>
    <a href="#contact" class="link-underline" data-anim data-delay="150">{t.services.link}</a>
  </div>
  <div class="ticker">
    <div class="ticker-track">
      {
        t.services.cards.map((c) => (
          <article class="service-card">
            <img src={c.img} alt={c.title} loading="lazy" draggable="false" />
            <h3>{c.title}</h3>
            <div class="tags">
              {c.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
