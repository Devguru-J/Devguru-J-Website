---
import Base from '../layouts/Base.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import HeroShader from './HeroShader.astro';
import { translations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang];
const path = lang === 'ko' ? '/ko/' : '/';

const ui =
  lang === 'ko'
    ? {
        workCat1: '01 / 제품',
        workCat2: '02 / 고객 작업',
        tileRow1: '기억 — SOFTWARE STUDIO',
        tileRow2: '제품 · 디자인 · 개발',
        tileRow3: '데스크톱 · 웹 · 클라우드',
        email: '이메일',
        github: 'GITHUB',
      }
    : {
        workCat1: '01 / PRODUCT',
        workCat2: '02 / CLIENT WORK',
        tileRow1: 'MEMORY — SOFTWARE STUDIO',
        tileRow2: 'PRODUCT · DESIGN · ENGINEERING',
        tileRow3: 'DESKTOP · WEB · CLOUD',
        email: 'EMAIL',
        github: 'GITHUB',
      };
---

<Base title={t.meta.title} description={t.meta.description} path={path} lang={lang} hreflang>
  <Nav lang={lang} />

  <main class="overflow-x-hidden">
    <!-- ================= Hero ================= -->
    <section class="relative flex min-h-[90dvh] items-center overflow-hidden px-5 pt-20 pb-32 md:px-12">
      <HeroShader />
      <div class="relative z-10 mx-auto grid w-full max-w-[1280px] grid-cols-1 gap-6 md:grid-cols-12">
        <div class="md:col-span-9 lg:col-span-8">
          <span class="label-mono reveal mb-8 inline-block text-ink-2" data-hero="overline">
            {t.hero.overline}
          </span>
          <h1 class="display-xl mb-10 text-ink" id="hero-title">
            <span class="hero-line"><span class="hero-line-inner">{t.hero.lines[0]}</span></span>
            <span class="hero-line"><span class="hero-line-inner">{t.hero.lines[1]}</span></span>
            <span class="hero-line"><span class="hero-line-inner text-ink-2">{t.hero.lines[2]}</span></span>
          </h1>
          <p class="reveal mb-12 max-w-xl text-[18px] leading-relaxed text-ink-2" data-hero="para">
            {t.hero.para}
          </p>
          <div class="reveal flex flex-col items-start gap-8 sm:flex-row sm:items-center" data-hero="cta">
            <a
              href="#work"
              class="label-mono magnetic bg-ink px-8 py-4 text-canvas transition-colors duration-300 hover:bg-amber"
            >
              {t.hero.ctaPrimary}
            </a>
            <a href="#about" class="label-mono link-slide pb-1 text-ink">{t.hero.ctaSecondary}</a>
          </div>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-[1280px] px-5 md:px-12">
      <div class="hline h-px bg-line"></div>
    </div>

    <!-- ================= Selected Work ================= -->
    <section class="mx-auto max-w-[1280px] px-5 py-32 md:px-12" id="work">
      <div class="reveal mb-24 flex items-baseline justify-between">
        <h2 class="headline-lg">{t.work.heading}</h2>
        <span class="label-mono text-ink-2">01 — 02</span>
      </div>

      <!-- 01 · Monkey Flash -->
      <div class="mb-40 grid grid-cols-1 items-center gap-6 md:grid-cols-12">
        <div class="reveal md:col-span-7">
          <div class="parallax-frame group aspect-video bg-container shadow-soft transition-shadow duration-500 hover:shadow-lift">
            <img
              src="/assets/work-monkeyflash.jpg"
              alt={t.work.mf.alt}
              class="h-full w-full object-cover"
              width="1600"
              height="1000"
              loading="eager"
              data-parallax
            />
          </div>
        </div>
        <div class="reveal md:col-span-4 md:col-start-9">
          <div class="mb-6 flex flex-wrap items-center gap-4">
            <span class="label-mono text-amber">{ui.workCat1}</span>
            <span class="label-mono text-ink-2">{t.work.mf.meta}</span>
          </div>
          <h3 class="headline-lg mb-6">MONKEY FLASH</h3>
          <p class="mb-8 text-[16px] leading-relaxed text-ink-2">{t.work.mf.desc}</p>
          <div class="mb-8 flex flex-wrap gap-2">
            {
              t.work.mf.badges.map((b) => (
                <span class="meta-mono bg-container-low px-4 py-2 uppercase text-ink-2">{b}</span>
              ))
            }
          </div>
          <span class="label-mono inline-flex items-center gap-2 text-ink">
            {t.work.mf.status}
            <span class="dot-pulse inline-block h-1.5 w-1.5 rounded-full bg-amber"></span>
          </span>
        </div>
      </div>

      <!-- 02 · KB Inc. -->
      <div class="grid grid-cols-1 items-center gap-6 md:grid-cols-12">
        <div class="reveal order-2 md:order-1 md:col-span-4">
          <div class="mb-6 flex flex-wrap items-center gap-4">
            <span class="label-mono text-amber">{ui.workCat2}</span>
            <span class="label-mono text-ink-2">{t.work.ops.meta}</span>
          </div>
          <h3 class="headline-lg mb-6">{t.work.ops.title}</h3>
          <p class="mb-8 text-[16px] leading-relaxed text-ink-2">{t.work.ops.desc}</p>
          <div class="mb-8 flex flex-wrap gap-2">
            {
              t.work.ops.badges.map((b) => (
                <span class="meta-mono bg-container-low px-4 py-2 uppercase text-ink-2">{b}</span>
              ))
            }
          </div>
          <a
            href={t.work.ops.url}
            target="_blank"
            rel="noopener"
            class="label-mono link-slide inline-flex items-center gap-2 pb-1 text-ink"
          >
            {t.work.ops.status}
            <span class="dot-pulse inline-block h-1.5 w-1.5 rounded-full bg-amber"></span>
          </a>
        </div>
        <div class="reveal order-1 md:order-2 md:col-span-7 md:col-start-6">
          <a href={t.work.ops.url} target="_blank" rel="noopener" class="block">
            <div class="parallax-frame group aspect-video bg-container shadow-soft transition-shadow duration-500 hover:shadow-lift">
              <img
                src="/assets/work-kbinc.jpg"
                alt={t.work.ops.alt}
                class="h-full w-full object-cover"
                width="1600"
                height="900"
                loading="lazy"
                data-parallax
              />
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- ================= Pipeline (dark curtain) ================= -->
    <section class="curtain bg-ink py-32 text-canvas">
      <div class="mx-auto max-w-[1280px] px-5 md:px-12">
        <span class="label-mono reveal mb-12 block text-ink-2">{t.pipeline.overline}</span>
        <div class="divide-y divide-ink-2/20">
          {
            t.pipeline.rows.map((row) => (
              <div class="reveal grid grid-cols-1 items-center gap-6 px-4 py-8 transition-colors hover:bg-white/5 md:grid-cols-12">
                <span class="label-mono md:col-span-2 text-ink-2">{row.idx}</span>
                <span class="headline-sm md:col-span-6">{row.name}</span>
                <span class="label-mono md:col-span-4 text-ink-2 md:text-right">{row.status}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ================= Capabilities ================= -->
    <section class="mx-auto max-w-[1280px] px-5 py-32 md:px-12" id="capabilities">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-12">
        <div class="reveal md:col-span-4">
          <h2 class="headline-lg mb-12">{t.capabilities.heading}</h2>
          <p class="text-[16px] leading-relaxed text-ink-2">{t.capabilities.intro}</p>
        </div>
        <div class="md:col-span-7 md:col-start-6">
          <div class="grid grid-cols-1 gap-12 sm:grid-cols-3">
            {
              t.capabilities.groups.map((g) => (
                <div class="reveal">
                  <h4 class="label-mono mb-6 uppercase tracking-widest text-amber">{g.label}</h4>
                  <ul class="space-y-4 text-[16px] leading-relaxed text-ink">
                    {g.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ================= Interstitial ================= -->
    <section class="bg-container-low px-5 py-48 md:px-12">
      <div class="reveal mx-auto max-w-[1280px] text-center">
        <h2 class="display-xl leading-tight text-ink">
          {t.interstitial.line1}
          <br class="hidden md:block" />
          <span class="italic text-ink-2">{t.interstitial.line2}</span>
        </h2>
      </div>
    </section>

    <!-- ================= Principles ================= -->
    <section class="mx-auto max-w-[1280px] px-5 py-32 md:px-12" id="principles">
      <h2 class="headline-lg reveal mb-24 text-center">{t.principles.heading}</h2>
      <div class="grid grid-cols-1 gap-x-24 gap-y-32 md:grid-cols-2">
        {
          t.principles.items.map((p, i) => (
            <div class:list={['reveal flex gap-8', i % 2 === 1 && 'md:mt-24']}>
              <span class="label-mono pt-1 text-amber">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <h3 class="headline-sm mb-4">{p.title}</h3>
                <p class="text-[16px] leading-relaxed text-ink-2">{p.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ================= About ================= -->
    <section class="overflow-hidden bg-surface py-32" id="about">
      <div class="mx-auto max-w-[1280px] px-5 md:px-12">
        <div class="grid grid-cols-1 items-center gap-6 md:grid-cols-12">
          <div class="reveal md:col-span-5">
            <div class="flex aspect-[4/5] flex-col justify-between bg-ink p-10 text-canvas shadow-lift">
              <span class="meta-mono uppercase text-canvas/50">{t.about.tileTop}</span>
              <span class="select-none text-[clamp(80px,10vw,140px)] font-semibold leading-none tracking-tighter">
                M<span class="text-amber">.</span>
              </span>
              <div class="meta-mono space-y-2 uppercase text-canvas/50">
                <p>{ui.tileRow1}</p>
                <p>{ui.tileRow2}</p>
                <p>{ui.tileRow3}</p>
              </div>
            </div>
          </div>
          <div class="reveal md:col-span-6 md:col-start-7">
            <span class="label-mono mb-6 block uppercase tracking-widest text-amber">{t.about.overline}</span>
            <h2 class="headline-lg mb-8 leading-tight">{t.about.name}</h2>
            <div class="space-y-6 text-[16px] leading-relaxed text-ink-2">
              {t.about.paras.map((p) => <p>{p}</p>)}
            </div>
            <div class="mt-12 flex gap-4">
              <a
                href="mailto:devguru.j610@gmail.com"
                class="label-mono bg-container-low px-8 py-4 shadow-soft transition-all duration-300 hover:bg-ink hover:text-canvas"
              >
                {ui.email}
              </a>
              <a
                href="https://github.com/Devguru-J"
                target="_blank"
                rel="noopener"
                class="label-mono bg-container-low px-8 py-4 shadow-soft transition-all duration-300 hover:bg-ink hover:text-canvas"
              >
                {ui.github}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer lang={lang} />
  </main>

  <script>
    import '../scripts/motion';
  </script>
</Base>
