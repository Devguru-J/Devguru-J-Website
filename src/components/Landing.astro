---
import Base from '../layouts/Base.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import { MONKEY_FLASH, KB_INC, homePath } from '../config/site';
import type { Lang } from '../config/site';
import { translations, format } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang];
const path = homePath(lang);
const altPath = homePath(lang === 'ko' ? 'en' : 'ko');

const mf = MONKEY_FLASH;
const kb = KB_INC;

/** Localised release date. Falls back to nothing when the fact is unconfirmed. */
const formatDate = (iso: string | null) =>
  iso
    ? new Intl.DateTimeFormat(lang === 'ko' ? 'ko-KR' : 'en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }).format(new Date(iso))
    : null;

/* Technical facts line — every entry omitted when unverified (§13.1). */
const mfFacts = [
  mf.version && format(t.a11y.version, { version: mf.version }),
  mf.minimumOs && format(t.a11y.requires, { os: mf.minimumOs }),
  mf.price && mf.price[lang].formatted,
  mf.updated && format(t.a11y.updated, { date: formatDate(mf.updated)! }),
].filter(Boolean) as string[];

const current = t.capabilities.items.filter((c) => c.current);
const extended = t.capabilities.items.filter((c) => !c.current);
---

<Base
  title={t.meta.title}
  description={t.meta.description}
  path={path}
  lang={lang}
  altPath={altPath}
  schema
>
  <Nav lang={lang} altPath={altPath} />

  <main id="main">
    <!-- ===================== Hero (§10.1 Direction A) ===================== -->
    <section class="shell hero">
      <div class="hero-inner">
        <p class="t-label accent" data-reveal>{t.hero.label}</p>
        <h1 class="t-display hero-headline" data-reveal data-reveal-delay="80">
          {t.hero.headline}
        </h1>
        <p class="t-lead measure muted hero-para" data-reveal data-reveal-delay="160">
          {t.hero.para}
        </p>
        <div class="hero-actions" data-reveal data-reveal-delay="240">
          <a href="#work" class="btn btn-primary">{t.hero.ctaPrimary}</a>
          <a href="#studio" class="btn btn-secondary">{t.hero.ctaSecondary}</a>
        </div>
      </div>
    </section>

    <!-- ===================== Work (§10.2, §13.1) ===================== -->
    <section class="shell section bordered" id="work" aria-labelledby="work-heading">
      <header class="section-head" data-reveal>
        <h2 class="t-h2" id="work-heading">{t.work.heading}</h2>
        <p class="t-lead measure muted">{t.work.intro}</p>
      </header>

      <!-- Monkey Flash — own product -->
      <article class="work">
        <div class="work-media" data-reveal>
          <a
            href={mf.storeUrl?.[lang]}
            class="media-frame"
            target="_blank"
            rel="noopener"
            tabindex="-1"
            aria-hidden="true"
          >
            <img
              src={mf.image[lang].src}
              alt={t.work.monkeyFlash.alt}
              width={mf.image[lang].width}
              height={mf.image[lang].height}
              loading="eager"
              decoding="async"
            />
          </a>
        </div>

        <div class="work-body" data-reveal data-reveal-delay="80">
          <p class="t-label muted">{t.work.monkeyFlash.kind}</p>
          <h3 class="t-h3 work-name">{mf.name}</h3>
          <p class="t-body measure muted">{t.work.monkeyFlash.desc}</p>

          <ul class="evidence">
            {t.work.monkeyFlash.evidence.map((e) => <li>{e}</li>)}
          </ul>

          <p class="status">
            <span class="sr-only">{t.a11y.statusPrefix} </span>
            <span class="status-dot" aria-hidden="true"></span>
            {t.status[mf.status]}
          </p>

          {mfFacts.length > 0 && <p class="t-mono facts">{mfFacts.join(' · ')}</p>}

          {
            mf.storeUrl && (
              <a href={mf.storeUrl[lang]} class="btn btn-secondary work-cta" target="_blank" rel="noopener">
                {t.work.monkeyFlash.cta}
                <span class="sr-only"> ({t.a11y.newTab})</span>
              </a>
            )
          }
        </div>
      </article>

      <!-- KB Inc. — client work -->
      <article class="work work--flip">
        <div class="work-media" data-reveal>
          <a
            href={kb.url}
            class="media-frame"
            target="_blank"
            rel="noopener"
            tabindex="-1"
            aria-hidden="true"
          >
            <img
              src={kb.image.src}
              alt={t.work.kbInc.alt}
              width={kb.image.width}
              height={kb.image.height}
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>

        <div class="work-body" data-reveal data-reveal-delay="80">
          <p class="t-label muted">{t.work.kbInc.kind}</p>
          <h3 class="t-h3 work-name">{kb.name[lang]}</h3>
          <p class="t-body measure muted">{t.work.kbInc.desc}</p>

          <ul class="evidence">
            {t.work.kbInc.evidence.map((e) => <li>{e}</li>)}
          </ul>

          <p class="status">
            <span class="sr-only">{t.a11y.statusPrefix} </span>
            <span class="status-dot" aria-hidden="true"></span>
            {t.status[kb.status]}
          </p>

          {
            kb.url && (
              <a href={kb.url} class="btn btn-secondary work-cta" target="_blank" rel="noopener">
                {t.work.kbInc.cta}
                <span class="sr-only"> ({t.a11y.newTab})</span>
              </a>
            )
          }
        </div>
      </article>
    </section>

    <!-- ===================== Capabilities (§12) ===================== -->
    <section class="shell section bordered" id="capabilities" aria-labelledby="cap-heading">
      <div class="cap-layout">
        <header class="cap-head" data-reveal>
          <h2 class="t-h2" id="cap-heading">{t.capabilities.heading}</h2>
          <p class="t-body measure muted">{t.capabilities.intro}</p>
        </header>

        <div class="cap-lists">
          <div class="cap-group">
            <h3 class="t-label cap-group-title accent" data-reveal>
              {t.capabilities.currentLabel}
            </h3>
            <dl>
              {
                current.map((c, i) => (
                  <div class="cap-item" data-reveal data-reveal-delay={i * 70}>
                    <dt class="t-h3 cap-title">{c.title}</dt>
                    <dd class="t-body measure muted">{c.body}</dd>
                  </div>
                ))
              }
            </dl>
          </div>

          <div class="cap-group">
            <h3 class="t-label cap-group-title muted" data-reveal>
              {t.capabilities.extendedLabel}
            </h3>
            <dl>
              {
                extended.map((c, i) => (
                  <div class="cap-item cap-item--extended" data-reveal data-reveal-delay={i * 70}>
                    <dt class="t-body cap-title-sm">{c.title}</dt>
                    <dd class="t-small measure muted">{c.body}</dd>
                  </div>
                ))
              }
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== How we work (§15) ===================== -->
    <section class="shell section bordered" id="how-we-work" aria-labelledby="process-heading">
      <header class="section-head" data-reveal>
        <h2 class="t-h2" id="process-heading">{t.process.heading}</h2>
      </header>

      <ol class="steps">
        {
          t.process.steps.map((s, i) => (
            <li class="step" data-reveal data-reveal-delay={i * 70}>
              <span class="t-mono step-index" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="t-h3 step-title">{s.title}</h3>
              <p class="t-body measure muted">{s.body}</p>
            </li>
          ))
        }
      </ol>

      <p class="philosophy t-h3" data-reveal>{t.philosophy}</p>
    </section>

    <!-- ===================== Studio (§3) ===================== -->
    <section class="shell section bordered" id="studio" aria-labelledby="studio-heading">
      <div class="studio-layout">
        <h2 class="t-h2 studio-heading" id="studio-heading" data-reveal>
          {t.studio.heading}
        </h2>
        <div class="studio-body">
          {
            t.studio.paras.map((p, i) => (
              <p class="t-lead measure" data-reveal data-reveal-delay={i * 60}>
                {p}
              </p>
            ))
          }
          <p class="closing t-h3" data-reveal>{t.closing}</p>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Base>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .muted {
    color: var(--color-ink-2);
  }
  .accent {
    color: var(--color-accent);
  }
  .bordered {
    border-top: 1px solid var(--color-line);
  }

  /* ---------------- Hero ---------------- */

  .hero {
    padding-block: clamp(72px, 12vh, 140px) clamp(88px, 12vw, 152px);
  }

  .hero-inner {
    max-width: 62ch;
  }

  .hero-headline {
    margin: 24px 0 32px;
  }

  .hero-para {
    margin-bottom: 40px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  /* ---------------- Section heads ---------------- */

  .section-head {
    margin-bottom: clamp(48px, 6vw, 72px);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ---------------- Work ---------------- */

  .work {
    display: grid;
    gap: 32px;
    align-items: center;
  }

  .work + .work {
    margin-top: clamp(72px, 9vw, 120px);
    padding-top: clamp(72px, 9vw, 120px);
    border-top: 1px solid var(--color-line);
  }

  @media (min-width: 1024px) {
    .work {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 24px;
    }
    .work-media {
      grid-column: 1 / span 7;
    }
    .work-body {
      grid-column: 9 / span 4;
    }
    .work--flip .work-media {
      grid-column: 6 / span 7;
      grid-row: 1;
    }
    .work--flip .work-body {
      grid-column: 1 / span 4;
      grid-row: 1;
    }
  }

  .work-name {
    margin: 12px 0 16px;
  }

  .evidence {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 24px 0;
  }
  .evidence li {
    padding: 6px 12px;
    border: 1px solid var(--color-line);
    border-radius: 2px;
    font-size: 13px;
    color: var(--color-ink-2);
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink);
  }
  /* a static marker, not a pulse (§13.3) */
  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success);
  }

  .facts {
    margin-top: 10px;
    color: var(--color-ink-3);
  }

  .work-cta {
    margin-top: 28px;
  }

  /* ---------------- Capabilities ---------------- */

  .cap-layout {
    display: grid;
    gap: 48px;
  }

  @media (min-width: 1024px) {
    .cap-layout {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 24px;
    }
    .cap-head {
      grid-column: 1 / span 4;
      position: sticky;
      top: 108px;
      align-self: start;
    }
    .cap-lists {
      grid-column: 6 / span 7;
    }
  }

  .cap-head h2 {
    margin-bottom: 16px;
  }

  .cap-group + .cap-group {
    margin-top: 56px;
    padding-top: 40px;
    border-top: 1px solid var(--color-line);
  }

  .cap-group-title {
    margin-bottom: 28px;
  }

  .cap-item + .cap-item {
    margin-top: 32px;
  }

  .cap-title {
    margin-bottom: 8px;
  }

  .cap-title-sm {
    font-weight: 500;
    margin-bottom: 6px;
  }

  /* ---------------- How we work ---------------- */

  .steps {
    display: grid;
    gap: 40px;
    counter-reset: step;
  }

  @media (min-width: 768px) {
    .steps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 56px 48px;
    }
  }

  .step-index {
    display: block;
    color: var(--color-accent);
    margin-bottom: 12px;
  }

  .step-title {
    margin-bottom: 10px;
  }

  .philosophy {
    margin-top: clamp(64px, 8vw, 96px);
    padding-top: clamp(40px, 5vw, 56px);
    border-top: 1px solid var(--color-line);
    max-width: 24ch;
    color: var(--color-ink);
  }

  /* ---------------- Studio ---------------- */

  .studio-layout {
    display: grid;
    gap: 32px;
  }

  @media (min-width: 1024px) {
    .studio-layout {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 24px;
    }
    .studio-heading {
      grid-column: 1 / span 3;
    }
    .studio-body {
      grid-column: 5 / span 7;
    }
  }

  .studio-body > p + p {
    margin-top: 24px;
  }

  .closing {
    margin-top: 48px;
    padding-top: 40px;
    border-top: 1px solid var(--color-line);
    color: var(--color-ink);
  }
</style>
