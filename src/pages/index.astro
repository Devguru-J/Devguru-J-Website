---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroShader from '../components/HeroShader.astro';
---

<Base
  title="Devguru-J — Independent Software Studio"
  description="Devguru is the independent workspace of Devguru-J, a Seoul-based engineer building precise software across desktop, web, and cloud — including Monkey Flash for macOS."
  path="/"
>
  <Nav />

  <main class="overflow-x-hidden">
    <!-- ================= Hero ================= -->
    <section class="relative flex min-h-[90dvh] items-center overflow-hidden px-5 pt-20 pb-32 md:px-12">
      <HeroShader />
      <div class="relative z-10 mx-auto grid w-full max-w-[1280px] grid-cols-1 gap-6 md:grid-cols-12">
        <div class="md:col-span-9 lg:col-span-8">
          <span class="label-mono reveal mb-8 inline-block text-ink-2" data-hero="overline">
            INDEPENDENT SOFTWARE BUILDER — SEOUL
          </span>
          <h1 class="display-xl mb-10 text-ink" id="hero-title">
            <span class="hero-line"><span class="hero-line-inner">Building what should exist.</span></span>
            <span class="hero-line"><span class="hero-line-inner">Nothing is impossible.</span></span>
            <span class="hero-line"><span class="hero-line-inner text-ink-2">Just engineering.</span></span>
          </h1>
          <p class="reveal mb-12 max-w-xl text-[18px] leading-relaxed text-ink-2" data-hero="para">
            I design and build software across desktop, web, cloud, and emerging platforms—turning
            everyday friction and complex business problems into clear, useful products.
          </p>
          <div class="reveal flex flex-col items-start gap-8 sm:flex-row sm:items-center" data-hero="cta">
            <a
              href="#work"
              class="label-mono magnetic bg-ink px-8 py-4 text-canvas transition-colors duration-300 hover:bg-amber"
            >
              EXPLORE THE WORK
            </a>
            <a href="#about" class="label-mono link-slide pb-1 text-ink"> ABOUT DEVGURU </a>
          </div>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-[1280px] px-5 md:px-12">
      <div class="hline h-px bg-line"></div>
    </div>

    <!-- ================= Selected Work ================= -->
    <section class="mx-auto max-w-[1280px] px-5 py-32 md:px-12" id="work">
      <div class="reveal mb-24 flex items-baseline justify-between">
        <h2 class="headline-lg">Selected Work</h2>
        <span class="label-mono text-ink-2">01 — 02</span>
      </div>

      <!-- 01 · Monkey Flash -->
      <div class="mb-40 grid grid-cols-1 items-center gap-6 md:grid-cols-12">
        <div class="reveal md:col-span-7">
          <div class="parallax-frame group aspect-video border border-line bg-container">
            <img
              src="/assets/work-monkeyflash.jpg"
              alt="Monkey Flash on macOS: the active window stays bright while the rest of the desktop is dimmed."
              class="h-full w-full object-cover"
              width="1600"
              height="1000"
              loading="eager"
              data-parallax
            />
          </div>
        </div>
        <div class="reveal md:col-span-4 md:col-start-9">
          <div class="mb-6 flex flex-wrap items-center gap-4">
            <span class="label-mono text-amber">01 / PRODUCT</span>
            <span class="label-mono text-ink-2">MACOS · FOCUS UTILITY</span>
          </div>
          <h3 class="headline-lg mb-6">MONKEY FLASH</h3>
          <p class="mb-8 text-[16px] leading-relaxed text-ink-2">
            A dimmer switch for your attention. Keeps the active window bright and quietly lowers
            everything else—no Accessibility, Screen Recording, or any system permission required.
          </p>
          <div class="mb-8 flex flex-wrap gap-2">
            <span class="meta-mono border border-line px-3 py-1.5 uppercase text-ink-2">Zero permissions</span>
            <span class="meta-mono border border-line px-3 py-1.5 uppercase text-ink-2">1% dim control</span>
            <span class="meta-mono border border-line px-3 py-1.5 uppercase text-ink-2">Fn reveal</span>
          </div>
          <span class="label-mono inline-flex items-center gap-2 text-ink">
            COMING TO THE MAC APP STORE
            <span class="dot-pulse inline-block h-1.5 w-1.5 rounded-full bg-amber"></span>
          </span>
        </div>
      </div>

      <!-- 02 · Operations platforms -->
      <div class="grid grid-cols-1 items-center gap-6 md:grid-cols-12">
        <div class="reveal order-2 md:order-1 md:col-span-4">
          <div class="mb-6 flex flex-wrap items-center gap-4">
            <span class="label-mono text-amber">02 / CLIENT WORK</span>
            <span class="label-mono text-ink-2">WEB · BUSINESS OPS</span>
          </div>
          <h3 class="headline-lg mb-6">OPERATIONS PLATFORMS</h3>
          <p class="mb-8 text-[16px] leading-relaxed text-ink-2">
            Complex operations, made clear. Bespoke web platforms that turn spreadsheet-grade
            business logic into fast, dependable tools people use every day.
          </p>
          <span class="label-mono inline-flex items-center gap-2 text-ink-2">
            PRIVATE ENGAGEMENTS · DETAILS ON REQUEST
          </span>
        </div>
        <div class="reveal order-1 md:order-2 md:col-span-7 md:col-start-6">
          <div class="parallax-frame group aspect-video border border-line bg-container">
            <img
              src="/assets/work-platform.jpg"
              alt="Editorial-style business operations workspace with dense but organized tables and timelines."
              class="h-full w-full object-cover"
              width="1376"
              height="768"
              loading="lazy"
              data-parallax
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ================= Pipeline (dark curtain) ================= -->
    <section class="curtain bg-ink py-32 text-canvas">
      <div class="mx-auto max-w-[1280px] px-5 md:px-12">
        <span class="label-mono reveal mb-12 block text-ink-2">NEXT — PIPELINE</span>
        <div class="divide-y divide-ink-2/20">
          <div class="reveal grid grid-cols-1 items-center gap-6 px-4 py-8 transition-colors hover:bg-white/5 md:grid-cols-12">
            <span class="label-mono md:col-span-2 text-ink-2">01 / RELEASE</span>
            <span class="headline-sm md:col-span-6">Monkey Flash 1.0 — Mac App Store</span>
            <span class="label-mono md:col-span-4 text-ink-2 md:text-right">IN REVIEW</span>
          </div>
          <div class="reveal grid grid-cols-1 items-center gap-6 px-4 py-8 transition-colors hover:bg-white/5 md:grid-cols-12">
            <span class="label-mono md:col-span-2 text-ink-2">02 / WIP</span>
            <span class="headline-sm md:col-span-6">Productivity utility</span>
            <span class="label-mono md:col-span-4 text-ink-2 md:text-right">IN DEVELOPMENT</span>
          </div>
          <div class="reveal grid grid-cols-1 items-center gap-6 px-4 py-8 transition-colors hover:bg-white/5 md:grid-cols-12">
            <span class="label-mono md:col-span-2 text-ink-2">03 / R&amp;D</span>
            <span class="headline-sm md:col-span-6">Automation toolkit</span>
            <span class="label-mono md:col-span-4 text-ink-2 md:text-right">RESEARCH PHASE</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ================= Capabilities ================= -->
    <section class="mx-auto max-w-[1280px] px-5 py-32 md:px-12" id="capabilities">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-12">
        <div class="reveal md:col-span-4">
          <h2 class="headline-lg mb-12">Capabilities</h2>
          <p class="text-[16px] leading-relaxed text-ink-2">
            A multidisciplinary approach to building technical products from zero to one.
          </p>
        </div>
        <div class="md:col-span-7 md:col-start-6">
          <div class="grid grid-cols-1 gap-12 sm:grid-cols-3">
            <div class="reveal">
              <h4 class="label-mono mb-6 uppercase tracking-widest text-amber">Product</h4>
              <ul class="space-y-4 text-[16px] leading-relaxed text-ink">
                <li>Strategy &amp; Vision</li>
                <li>UI/UX Design</li>
                <li>Prototyping</li>
                <li>Systems Design</li>
              </ul>
            </div>
            <div class="reveal">
              <h4 class="label-mono mb-6 uppercase tracking-widest text-amber">Engineering</h4>
              <ul class="space-y-4 text-[16px] leading-relaxed text-ink">
                <li>macOS Native Apps</li>
                <li>Frontend Architectures</li>
                <li>Cloud Infrastructure</li>
                <li>Performance Audit</li>
              </ul>
            </div>
            <div class="reveal">
              <h4 class="label-mono mb-6 uppercase tracking-widest text-amber">Delivery</h4>
              <ul class="space-y-4 text-[16px] leading-relaxed text-ink">
                <li>Agile Execution</li>
                <li>Direct Collaboration</li>
                <li>Technical SEO</li>
                <li>Post-launch Support</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================= Interstitial ================= -->
    <section class="border-y border-line bg-container-low px-5 py-48 md:px-12">
      <div class="reveal mx-auto max-w-[1280px] text-center">
        <h2 class="display-xl leading-tight text-ink">
          No fixed platform. No fixed category.
          <br class="hidden md:block" />
          <span class="italic text-ink-2">Just the right product for the problem.</span>
        </h2>
      </div>
    </section>

    <!-- ================= Principles ================= -->
    <section class="mx-auto max-w-[1280px] px-5 py-32 md:px-12" id="principles">
      <h2 class="headline-lg reveal mb-24 text-center">Guiding Principles</h2>
      <div class="grid grid-cols-1 gap-x-24 gap-y-32 md:grid-cols-2">
        <div class="reveal flex gap-8">
          <span class="label-mono pt-1 text-amber">01</span>
          <div>
            <h3 class="headline-sm mb-4">Precision over speed</h3>
            <p class="text-[16px] leading-relaxed text-ink-2">
              I build correctly once, rather than fast twice. Every line of code is intentional.
            </p>
          </div>
        </div>
        <div class="reveal flex gap-8 md:mt-24">
          <span class="label-mono pt-1 text-amber">02</span>
          <div>
            <h3 class="headline-sm mb-4">Functional beauty</h3>
            <p class="text-[16px] leading-relaxed text-ink-2">
              Design is not what it looks like, but how it works. Clarity is the highest aesthetic
              goal.
            </p>
          </div>
        </div>
        <div class="reveal flex gap-8">
          <span class="label-mono pt-1 text-amber">03</span>
          <div>
            <h3 class="headline-sm mb-4">Technical depth</h3>
            <p class="text-[16px] leading-relaxed text-ink-2">
              Powerful tools shouldn’t be hidden behind dumbed-down interfaces. I embrace the
              command line.
            </p>
          </div>
        </div>
        <div class="reveal flex gap-8 md:mt-24">
          <span class="label-mono pt-1 text-amber">04</span>
          <div>
            <h3 class="headline-sm mb-4">Digital craft</h3>
            <p class="text-[16px] leading-relaxed text-ink-2">
              Software as an artisanal craft. Attention to detail is the competitive advantage.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ================= About ================= -->
    <section class="overflow-hidden border-t border-line bg-surface py-32" id="about">
      <div class="mx-auto max-w-[1280px] px-5 md:px-12">
        <div class="grid grid-cols-1 items-center gap-6 md:grid-cols-12">
          <div class="reveal md:col-span-5">
            <div
              class="flex aspect-[4/5] flex-col justify-between border border-line bg-ink p-10 text-canvas"
            >
              <span class="meta-mono uppercase text-canvas/50">The independent workspace of</span>
              <span class="select-none text-[clamp(80px,10vw,140px)] font-semibold leading-none tracking-tighter">
                DG<span class="text-amber">.</span>
              </span>
              <div class="meta-mono space-y-2 uppercase text-canvas/50">
                <p>DEVGURU — SEOUL, KR</p>
                <p>37.5665° N / 126.9780° E</p>
                <p>DESKTOP · WEB · CLOUD</p>
              </div>
            </div>
          </div>
          <div class="reveal md:col-span-6 md:col-start-7">
            <span class="label-mono mb-6 block uppercase tracking-widest text-amber">The Builder</span>
            <h2 class="headline-lg mb-8 leading-tight">Devguru-J</h2>
            <div class="space-y-6 text-[16px] leading-relaxed text-ink-2">
              <p>
                Devguru is the independent workspace of Devguru-J, a Seoul-based engineer and
                designer obsessed with building high-performance digital tools.
              </p>
              <p>
                With a background spanning distributed systems and editorial design, I bridge the
                gap between heavy engineering and human-centric interfaces. I don’t just write
                code; I design systems that solve problems for the long term.
              </p>
              <p>
                Currently focused on macOS productivity utilities and specialized web applications
                for complex business operations.
              </p>
            </div>
            <div class="mt-12 flex gap-4">
              <a
                href="mailto:devguru.j610@gmail.com"
                class="label-mono border border-line px-6 py-3 transition-all hover:border-amber hover:text-amber"
              >
                EMAIL
              </a>
              <a
                href="https://github.com/Devguru-J"
                target="_blank"
                rel="noopener"
                class="label-mono border border-line px-6 py-3 transition-all hover:border-amber hover:text-amber"
              >
                GITHUB
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>

  <script>
    import '../scripts/motion';
  </script>
</Base>
