    font-size: clamp(28px, 3.4vw, 36px);
    letter-spacing: -0.02em;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .legal .eff {
    color: var(--color-ink-2);
    font-size: 15px;
    margin-bottom: 32px;
    max-width: 65ch;
  }
  .legal h2 {
    font-size: 19px;
    letter-spacing: -0.01em;
    font-weight: 500;
    margin: 44px 0 12px;
  }
  .legal h3 {
    font-size: 16px;
    font-weight: 500;
    margin: 24px 0 6px;
    color: var(--color-ink);
  }
  .legal p {
    color: var(--color-ink-2);
    line-height: 1.7;
    margin-bottom: 14px;
    max-width: 65ch;
  }
  .legal ol,
  .legal ul {
    color: var(--color-ink-2);
    line-height: 1.7;
    margin: 0 0 14px;
    padding-left: 22px;
    max-width: 65ch;
  }
  .legal ol {
    list-style: decimal;
  }
  .legal ul {
    list-style: disc;
  }
  .legal li {
    margin-bottom: 6px;
  }
  .legal strong {
    color: var(--color-ink);
  }
  .legal a {
